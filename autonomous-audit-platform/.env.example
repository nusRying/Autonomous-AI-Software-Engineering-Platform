# App
APP_NAME="Advanced Software Auditor"
APP_VERSION="0.2.0"
DEBUG=true

# Database
DATABASE_URL="sqlite+aiosqlite:///./audit_platform.db"

# Redis (for Celery & caching)
REDIS_URL="redis://localhost:6379/0"

# Security (JWT & RBAC)
SECRET_KEY="super-secret-change-me-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MinIO (S3 Storage)
USE_MINIO=true
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="audit-reports"
MINIO_REGION="us-east-1"

# Temporal (Workflow Scheduling)
USE_TEMPORAL=true
TEMPORAL_HOST="localhost:7233"
TEMPORAL_NAMESPACE="default"

# LLM Configuration
DEFAULT_LLM_PROVIDER="openai"
DEFAULT_LLM_MODEL="gpt-4o-mini"

# Pre-set API Keys (optional - can also add via UI)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Docker Sandbox
SANDBOX_MEMORY_LIMIT="512m"
SANDBOX_CPU_QUOTA=50000
SANDBOX_TIMEOUT_SECONDS=60

# Local Storage
AUDIT_OUTPUT_DIR="./audit_reports"
